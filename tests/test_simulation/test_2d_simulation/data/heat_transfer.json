{
  "characteristic_dimensions": [
    {
      "value": 0.4,
      "name": "Length",
      "hint": "geometries.shapes[name=WaterBody].upper_bound"
    },
    {
      "value": 1.0,
      "name": "Pressure",
      "hint": "fluid_boundary_conditions[oriented_box=Inlet].pressure"
    },
    {
      "value": 1.0,
      "name": "Density",
      "hint": "fluid_bodies[name=WaterBody].material.density"
    }
  ],

  "simulation_type": "fluid_dynamics",

  "geometries": {
    "global_resolution": { "characteristic_length_particles": 25 },
    "shapes": [
      {
        "name": "WaterBody",
        "type": "bounding_box",
        "lower_bound": [0.0, 0.0],
        "upper_bound": [2.0, 0.4]
      },
      {
        "name": "WallBoundary",
        "type": "multipolygon",
        "polygons": [
          {
            "operation": "union",
            "type": "bounding_box",
            "lower_bound": [0.0, -0.1],
            "upper_bound": [2.0, 0.5]
          },
          {
            "operation": "subtraction",
            "type": "bounding_box",
            "lower_bound": [-0.1, 0.0],
            "upper_bound": [2.1, 0.4]
          }
        ]
      }
    ],
    "oriented_boxes": [
      {
        "name": "Inlet",
        "type": "in_outlet",
        "center": [0.0, 0.2],
        "normal": [1.0, 0.0],
        "radius": 0.2
      },
      {
        "name": "Outlet",
        "type": "in_outlet",
        "center": [2.0, 0.2],
        "normal": [-1.0, 0.0],
        "radius": 0.2
      },
      {
        "name": "UpperWall",
        "type": "region",
        "half_size": [1.0, 0.05],
        "transform": {
          "translation": [1.0, 0.45],
          "rotation_angle": 0.0
        }
      },
      {
        "name": "LowerWall",
        "type": "region",
        "half_size": [1.0, 0.05],
        "transform": {
          "translation": [1.0, -0.05],
          "rotation_angle": 0.0
        }
      }
    ]
  },

  "particle_generation": {
    "build_and_run": true,
    "settings": {
      "bodies": [
        {
          "name": "WaterBody"
        },
        {
          "name": "WallBoundary",
          "solid_body": {}
        }
      ],
      "relaxation_parameters": {
        "total_iterations": 1000
      }
    }
  },

  "fluid_bodies": [
    {
      "name": "WaterBody",
      "material": {
        "type": "weakly_compressible_fluid",
        "density": 1.0,
        "max_velocity_factor": 1.0,
        "viscosity": {
          "Reynolds_number": 50
        },
        "thermal_properties": {
          "thermal_conductivity": 0.6,
          "volumetric_heat_capacity": 4181.3
        }
      },
      "particle_reserve_factor": 0.2
    }
  ],

  "solid_bodies": [
    {
      "name": "WallBoundary",
      "material": {
        "type": "rigid_body",
        "thermal_properties": {
          "thermal_boundary": "Dirichlet"
        }
      }
    }
  ],

  "fluid_boundary_conditions": [
    {
      "body_name": "WaterBody",
      "oriented_box": "Inlet",
      "type": "bi_directional",
      "pressure": 1.0
    },
    {
      "body_name": "WaterBody",
      "oriented_box": "Outlet",
      "type": "bi_directional",
      "pressure": 0.0
    }
  ],

  "initial_conditions": [
    {
      "body_name": "WallBoundary",
      "assignments": [
        {
          "region": "UpperWall",
          "variable": { "real_type": "Temperature" },
          "value": 400.0
        },
        {
          "region": "LowerWall",
          "variable": { "real_type": "Temperature" },
          "value": 300.0
        }
      ]
    },
    {
      "body_name": "WaterBody",
      "assignments": [
        {
          "variable": { "real_type": "Temperature" },
          "value": 350.0
        }
      ]
    }
  ],

  "extra_state_recording": [
    {
      "name": "WaterBody",
      "variables": [{ "real_type": ["Density"], "int_type": ["BufferIndicator", "Indicator"] }]
    },
    {
      "name": "WallBoundary",
      "variables": [{ "vector_type": ["NormalDirection"] }]
    }
  ],

  "solver_parameters": {
    "end_time": 10.0,
    "output_interval": 0.1,
    "screen_interval": 100,
    "fluid_dynamics": {
      "acoustic_cfl": 0.6,
      "advection_cfl": 0.25,
      "surface_type": "open_boundary",
      "particle_sort_frequency": 100
    }
  }
